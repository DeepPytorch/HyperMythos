import torch
import torch.nn as nn
import torch.nn.functional as F

class OptimizedSparseMoE(nn.Module):
    def __init__(self, d_model, num_experts, expert_hidden_dim, top_k=2):
        super().__init__()
        self.num_experts = num_experts
        self.top_k = top_k
        self.gate = nn.Linear(d_model, num_experts)
        
        self.experts = nn.ModuleList([
            nn.Sequential(
                nn.Linear(d_model, expert_hidden_dim, bias=False),
                nn.GELU(),
                nn.Linear(expert_hidden_dim, d_model, bias=False),
            ) for _ in range(num_experts)
        ])

    def forward(self, x):
        orig_shape = x.shape
        x = x.view(-1, x.size(-1)) 
        
        gate_logits = self.gate(x)
        weights, selected_experts = torch.topk(gate_logits, self.top_k, dim=-1)
        weights = F.softmax(weights, dim=-1) 

        final_output = torch.zeros_like(x)

        for i in range(self.num_experts):
            mask = (selected_experts == i)
            if not mask.any():
                continue
            
            token_indices, k_slots = torch.where(mask)
            expert_out = self.experts[i](x[token_indices])
            final_output[token_indices] += weights[token_indices, k_slots].unsqueeze(-1) * expert_out

        return final_output.view(*orig_shape)

class LoopedTransformerMoE(nn.Module):
    def __init__(
        self,
        vocab_size,
        d_model=16384,
        num_heads=128,
        num_experts=1024,
        expert_hidden_dim=192000, # Calculated for ~20T total params
        num_layers=32,
        halt_threshold=0.85, # Confidence needed for an "easy" token to exit
        max_seq_len=1048576,
    ):
        super().__init__()
        self.token_embedding = nn.Embedding(vocab_size, d_model)
        self.position_embedding = nn.Parameter(torch.zeros(1, max_seq_len, d_model))
        self.halt_threshold = halt_threshold
        
        # 32 Layers, each with its own Attention, MoE, and Halt Head
        self.layers = nn.ModuleList([
            nn.ModuleDict({
                "attention": nn.MultiheadAttention(d_model, num_heads, batch_first=True),
                "moe": OptimizedSparseMoE(d_model, num_experts, expert_hidden_dim, top_k=2),
                "halt_head": nn.Sequential(nn.Linear(d_model, 1), nn.Sigmoid()),
                "norm1": nn.LayerNorm(d_model),
                "norm2": nn.LayerNorm(d_model)
            }) for _ in range(num_layers)
        ])

        self.output_proj = nn.Linear(d_model, d_model)
        self.final_norm = nn.LayerNorm(d_model)

    def forward(self, input_ids):
        # Embeddings
        x = self.token_embedding(input_ids)
        x = x + self.position_embedding[:, :input_ids.size(1), :]
        
        batch_size, seq_len, _ = x.shape
        device = x.device
        
        # Buffers to track halted tokens
        final_hidden_states = torch.zeros_like(x)
        is_halted = torch.zeros((batch_size, seq_len), dtype=torch.bool, device=device)
        
        # Layer Processing with Early Exit logic
        for i, layer in enumerate(self.layers):
            if is_halted.all():
                break # All tokens have finished; exit early
                
            # Attention + Residual
            norm_x = layer["norm1"](x)
            attn_out, _ = layer["attention"](norm_x, norm_x, norm_x)
            x = x + attn_out
            
            # MoE + Residual
            moe_out = layer["moe"](layer["norm2"](x))
            x = x + self.output_proj(moe_out)
            
            # Early Exit Check
            # Predict exit probability for each token
            halt_prob = layer["halt_head"](x).squeeze(-1)
            
            # Identify "Easy" tokens that just crossed the threshold
            exit_mask = (halt_prob > self.halt_threshold) & (~is_halted)
            
            if exit_mask.any():
                final_hidden_states[exit_mask] = x[exit_mask]
                is_halted[exit_mask] = True
        
        # Finalization
        # Hard tokens that reached the very end without halting
        final_hidden_states[~is_halted] = x[~is_halted]
        
        return self.final_norm(final_hidden_states)

